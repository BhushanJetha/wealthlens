# ================================================
# WealthLens — Copy to .env.local and fill values
# NEVER put real secrets in this file — it is committed to git.
# ================================================

# Supabase (get from supabase.com > Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic Claude (get from console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini (get from aistudio.google.com)
GEMINI_API_KEY=your-gemini-api-key

# Encryption key for financial data at rest (generate: openssl rand -hex 32)
ENCRYPTION_SECRET=your-32-byte-hex-secret

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_AED_TO_INR=22.80
