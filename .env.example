# ================================================
# WealthLens — Copy to .env.local and fill values
# ================================================

# Supabase (get from supabase.com > Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Anthropic Claude (get from console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini (get from aistudio.google.com)
GEMINI_API_KEY=AIza...

# Encryption key for financial data at rest (generate: openssl rand -hex 32)
ENCRYPTION_SECRET=your-64-char-hex-string-here

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_AED_TO_INR=22.80
